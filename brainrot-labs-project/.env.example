# =============================================
# FRONTEND — variabili Vite (prefix VITE_)
# =============================================

# Firebase Web SDK configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_FIRESTORE_DB_ID=

# Error tracking (opzionale)
VITE_SENTRY_DSN=

# =============================================
# CLOUD FUNCTIONS — variabili server (NO prefix)
# =============================================

# AI Studio inietta automaticamente GEMINI_API_KEY a runtime
GEMINI_API_KEY=

# URL dell'app (iniettato da AI Studio / Cloud Run)
APP_URL=

# Printful API key — se vuoto usa MockProvider (sviluppo)
PRINTFUL_API_KEY=
